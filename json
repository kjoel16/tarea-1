[Unit]
Description=API Modernizacion Caja
After=network.target

[Service]
User=root
WorkingDirectory=/opt/apisModCajaJav
ExecStart=/usr/bin/java -jar /opt/apisModCajaJav/API-02-Consulta-1.0-SNAPSHOT.jar --server.port=10050
SuccessExitStatus=143
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target



ExecStart=/usr/bin/java -XX:+UseSerialGC -jar /opt/apisModCajaJav/API-02-Consulta-1.0-SNAPSHOT.jar --server.port=10050
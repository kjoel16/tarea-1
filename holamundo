<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Caja Bancaria</title>

<style>
:root{
  --primary:#ed1c24;
  --bg:#f4f4f4;
  --card:#ffffff;
}

body{
  margin:0;
  font-family:'Segoe UI', sans-serif;
  background:var(--bg);
  display:flex;
}

/* SIDEBAR */
.sidebar{
  width:220px;
  background:#fff;
  height:100vh;
  padding:20px;
  box-shadow:2px 0 10px rgba(0,0,0,0.05);
}

.sidebar h2{
  color:var(--primary);
  margin-bottom:20px;
}

.sidebar button{
  width:100%;
  padding:12px;
  margin-bottom:10px;
  border:none;
  background:none;
  text-align:left;
  cursor:pointer;
  border-radius:6px;
  font-weight:500;
}

.sidebar button:hover{
  background:rgba(237,28,36,0.1);
  color:var(--primary);
}

/* MAIN */
.main{
  flex:1;
  padding:20px;
}

/* HEADER */
.header{
  background:var(--card);
  padding:15px;
  border-radius:10px;
  box-shadow:0 4px 10px rgba(0,0,0,0.05);
  margin-bottom:20px;
  display:flex;
  justify-content:space-between;
}

/* CARDS */
.cards{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
  gap:20px;
}

.card{
  background:var(--card);
  padding:20px;
  border-radius:10px;
  box-shadow:0 4px 10px rgba(0,0,0,0.05);
  border-top:5px solid var(--primary);
}

.card h3{
  margin:0 0 10px 0;
}

.card button{
  margin-top:10px;
  padding:10px;
  border:none;
  background:var(--primary);
  color:white;
  border-radius:5px;
  cursor:pointer;
  width:100%;
}

.card button:hover{
  opacity:0.9;
}
</style>
</head>

<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <h2>LabCaja</h2>

  <button onclick="accion('Deposito a Cuenta')">💰 Depósito</button>
  <button onclick="accion('Retiros')">💸 Retiros</button>
  <button onclick="accion('Cheques')">📄 Cheques</button>
  <button onclick="accion('Administración de Caja')">🏦 Caja</button>
</div>

<!-- MAIN -->
<div class="main">

  <!-- HEADER -->
  <div class="header">
    <h3>Menú Principal</h3>
    <input type="text" placeholder="Buscar..." style="padding:8px;border-radius:5px;border:1px solid #ccc;">
  </div>

  <!-- CARDS -->
  <div class="cards">

    <div class="card">
      <h3>Depósito</h3>
      <p>Realizar depósitos a cuentas</p>
      <button onclick="accion('Deposito a Cuenta')">Entrar</button>
    </div>

    <div class="card">
      <h3>Retiros</h3>
      <p>Retirar dinero de cuentas</p>
      <button onclick="accion('Retiros')">Entrar</button>
    </div>

    <div class="card">
      <h3>Cheques</h3>
      <p>Consulta de cheques</p>
      <button onclick="accion('Cheques')">Entrar</button>
    </div>

    <div class="card">
      <h3>Caja</h3>
      <p>Administración de caja</p>
      <button onclick="accion('Administración de Caja')">Entrar</button>
    </div>

  </div>

</div>

<script>
function accion(tipo){
  console.log("Opción seleccionada:", tipo);

  if (tipo === "Deposito a Cuenta"){
    window.location.href = 'index.html';
  }
  if (tipo === "Retiros"){
    window.location.href = 'retirosConCuenta.html';
  }
  if (tipo === "Cheques"){
    window.location.href = 'consultaCheque.html';
  }
  if (tipo === "Administración de Caja"){
    window.location.href = 'admincaja.html';
  }
}
</script>

</body>
</html>
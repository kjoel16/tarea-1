<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Caja Bancaria</title>

<style>

:root{
--primary:#ed1c24;
--bg:#f4f4f4;
}

body{
font-family:'Segoe UI',sans-serif;
background:var(--bg);
display:flex;
justify-content:center;
align-items:center;
height:100vh;
margin:0;
}

.card{
background:white;
padding:30px;
border-radius:10px;
box-shadow:0 4px 15px rgba(0,0,0,0.1);
width:380px;
border-top:5px solid var(--primary);
text-align:center;
}

button{
width:100%;
padding:12px;
margin-top:10px;
background:var(--primary);
color:white;
border:none;
border-radius:5px;
font-weight:bold;
cursor:pointer;
}

button:hover{
opacity:0.9;
}

.menu button{
margin-bottom:10px;
}

.logo{
width:220px;
margin-bottom:20px;
}

.hidden{
display:none;
}

</style>

</head>

<body>

<div class="card">

<!-- PANTALLA INICIO -->
<div id="pantallaInicio">

<img class="logo" src="https://upload.wikimedia.org/wikipedia/commons/thumb/3/3a/Davivienda_logo.svg/512px-Davivienda_logo.svg.png">

<button onclick="abrirMenu()">Ingresar</button>

</div>


<!-- MENU -->
<div id="menuPrincipal" class="hidden">

<h2>Menú Caja</h2>

<div class="menu">

<button onclick="accion('Deposito a Cuenta')">
Depósito a Cuenta
</button>

<button onclick="accion('Retiros')">
Retiros
</button>

<button onclick="accion('Cheques')">
Cheques
</button>

<button onclick="accion('Compra y Venta de Efectivo')">
Compra y Venta de Efectivo
</button>

<button onclick="accion('Prestamos')">
Préstamos
</button>

<button onclick="accion('Administración de Cuentas')">
Administración de Cuentas
</button>

</div>

<button onclick="volverInicio()">Salir</button>

</div>

</div>


<script>

function abrirMenu(){

document.getElementById("pantallaInicio").style.display="none";
document.getElementById("menuPrincipal").style.display="block";

}


function volverInicio(){

document.getElementById("menuPrincipal").style.display="none";
document.getElementById("pantallaInicio").style.display="block";

}


function accion(tipo){

console.info("Opción seleccionada:",tipo);

/* aquí luego puedes redirigir */

alert("Entrando a: " + tipo);

}

</script>

</body>
</html>